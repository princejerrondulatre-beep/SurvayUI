local Survay = {}
Survay.Gui = Instance.new("ScreenGui")
Survay.Gui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
Survay.Gui.Name = "SurvayGui"

-- Theme System (10 Base Themes)
local Themes = {
    Dark = {
        Main = Color3.fromRGB(30, 30, 30),
        Secondary = Color3.fromRGB(40, 40, 40),
        Accent = Color3.fromRGB(70, 130, 180),
        Text = Color3.new(1,1,1)
    },
    Light = {
        Main = Color3.fromRGB(240, 240, 240),
        Secondary = Color3.fromRGB(200, 200, 200),
        Accent = Color3.fromRGB(70, 130, 180),
        Text = Color3.new(0,0,0)
    },
    Synapse = {
        Main = Color3.fromRGB(47, 49, 54),
        Secondary = Color3.fromRGB(54, 57, 62),
        Accent = Color3.fromRGB(160, 224, 192),
        Text = Color3.new(1,1,1)
    },
    Rayfield = {
        Main = Color3.fromRGB(28, 28, 28),
        Secondary = Color3.fromRGB(35, 35, 35),
        Accent = Color3.fromRGB(100, 250, 212),
        Text = Color3.new(1,1,1)
    },
    Purple = {
        Main = Color3.fromRGB(52, 44, 73),
        Secondary = Color3.fromRGB(63, 53, 87),
        Accent = Color3.fromRGB(170, 129, 219),
        Text = Color3.new(1,1,1)
    },
    Green = {
