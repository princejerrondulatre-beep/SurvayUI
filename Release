-- [[ UTILITY: INTERNAL TWEEN WRAPPER ]] --
local function CreateTween(obj, info, params)
    local t = TweenService:Create(obj, TweenInfo.new(unpack(info)), params)
    t:Play()
    return t
end

-- [[ UTILITY: MODERN RIPPLE SYSTEM ]] --
local function Ripple(obj)
    task.spawn(function()
        local mousePos = UserInputService:GetMouseLocation()
        local relativePos = mousePos - obj.AbsolutePosition
        local circle = Instance.new("Frame", obj)
        circle.ZIndex = 10
        circle.BackgroundColor3 = Color3.new(1,1,1)
        circle.BackgroundTransparency = 0.8
        circle.BorderSizePixel = 0
        circle.Position = UDim2.new(0, relativePos.X, 0, relativePos.Y)
        Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)
        
        CreateTween(circle, {0.5}, {
            Size = UDim2.new(0, 300, 0, 300),
            Position = UDim2.new(0, relativePos.X - 150, 0, relativePos.Y - 150),
            BackgroundTransparency = 1
        })
        task.wait(0.5)
        circle:Destroy()
    end)
end

-- [[ UTILITY: SMART DRAG LOGIC ]] --
local function MakeDraggable(topbar, obj)
    local dragging, dragInput, dragStart, startPos
    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = obj.Position
            input.Changed:Connect(function() 
                if input.UserInputState == Enum.UserInputState.End then dragging = false end 
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- [[ NOTIFICATION ENGINE (GLOBAL) ]] --
local GlobalNotifGui = Instance.new("ScreenGui", CoreGui)
GlobalNotifGui.Name = "Survay_Framework_Notifs"
local NotifHolder = Instance.new("Frame", GlobalNotifGui)
NotifHolder.Size = UDim2.new(0, 280, 1, -20); NotifHolder.Position = UDim2.new(1, -290, 0, 10); NotifHolder.BackgroundTransparency = 1
local NotifLayout = Instance.new("UIListLayout", NotifHolder)
NotifLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom; NotifLayout.Padding = UDim.new(0, 12)

function Survay:Notify(data)
    local theme = Survay.Themes.BloodRed
    local N = Instance.new("Frame", NotifHolder)
    N.Size = UDim2.new(1, 0, 0, 80); N.BackgroundColor3 = theme.Main; N.BackgroundTransparency = 0.1
    Instance.new("UICorner", N).CornerRadius = UDim.new(0, 12)
    local NS = Instance.new("UIStroke", N); NS.Color = theme.Accent; NS.Thickness = 2
    
    local Icon = Instance.new("TextLabel", N)
    Icon.Size = UDim2.new(0, 35, 0, 35); Icon.Position = UDim2.new(0, 12, 0, 12); Icon.Text = "!"; Icon.TextColor3 = theme.Accent; Icon.Font = Enum.Font.GothamBold; Icon.BackgroundTransparency = 1; Icon.TextSize = 20
    
    local T = Instance.new("TextLabel", N)
    T.Size = UDim2.new(1, -60, 0, 25); T.Position = UDim2.new(0, 50, 0, 12); T.Text = data.Title or "System Message"; T.TextColor3 = theme.Text; T.Font = Enum.Font.GothamBold; T.TextXAlignment = 0; T.BackgroundTransparency = 1
    
    local C = Instance.new("TextLabel", N)
    C.Size = UDim2.new(1, -24, 0, 35); C.Position = UDim2.new(0, 12, 0, 40); C.Text = data.Content or ""; C.TextColor3 = Color3.fromRGB(190, 190, 190); C.Font = Enum.Font.Gotham; C.TextXAlignment = 0; C.BackgroundTransparency = 1; C.TextWrapped = true; C.TextSize = 13

    N.Position = UDim2.new(2, 0, 0, 0)
    CreateTween(N, {0.65, Enum.EasingStyle.Back}, {Position = UDim2.new(0, 0, 0, 0)})
    
    task.spawn(function()
        task.wait(data.Duration or 4)
        local out = CreateTween(N, {0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In}, {Position = UDim2.new(2, 0, 0, 0)})
        out.Completed:Wait()
        N:Destroy()
    end)
end

-- [[ MAIN FRAMEWORK CONSTRUCTOR ]] --
function Survay:CreateWindow(options)
    local theme = Survay.Themes[options.Theme] or Survay.Themes.BloodRed
    local ScreenGui = Instance.new("ScreenGui", CoreGui)
    ScreenGui.Name = "Survay_Mega_Engine"
    ScreenGui.ResetOnSpawn = false

    -- MAIN COMPONENT
    local MainFrame = Instance.new("Frame", ScreenGui)
    MainFrame.Size = UDim2.new(0, 620, 0, 440); MainFrame.Position = UDim2.new(0.5, -310, 0.5, -220); MainFrame.BackgroundColor3 = theme.Main; MainFrame.BackgroundTransparency = 0.1; MainFrame.Visible = false
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 18); local MS = Instance.new("UIStroke", MainFrame); MS.Color = theme.Stroke; MS.Thickness = 1.8

    -- FRAME TOPBAR
    local TopBar = Instance.new("Frame", MainFrame)
    TopBar.Size = UDim2.new(1, 0, 0, 60); TopBar.BackgroundColor3 = theme.Second; TopBar.BackgroundTransparency = 0.35; Instance.new("UICorner", TopBar)
    MakeDraggable(TopBar, MainFrame)
    
    local Title = Instance.new("TextLabel", TopBar)
    Title.Size = UDim2.new(1, -40, 1, 0); Title.Position = UDim2.new(0, 25, 0, 0); Title.Text = options.Name .. "  ||  " .. (options.GameName or "Ron Hub"); Title.TextColor3 = theme.Text; Title.Font = Enum.Font.GothamBold; Title.TextSize = 18; Title.TextXAlignment = 0; Title.BackgroundTransparency = 1

    -- NAVIGATION SIDEBAR
    local TabHolder = Instance.new("ScrollingFrame", MainFrame)
    TabHolder.Size = UDim2.new(0, 160, 1, -90); TabHolder.Position = UDim2.new(0, 15, 0, 75); TabHolder.BackgroundTransparency = 1; TabHolder.ScrollBarThickness = 0
    local TabList = Instance.new("UIListLayout", TabHolder); TabList.Padding = UDim.new(0, 12)

    -- PAGE VIEWPORT
    local PageContainer = Instance.new("Frame", MainFrame)
    PageContainer.Size = UDim2.new(1, -210, 1, -90); PageContainer.Position = UDim2.new(0, 190, 0, 75); PageContainer.BackgroundTransparency = 1

    -- FLOATING OVERLAY TOGGLE
    local FloatBtn
    if options.CreateFloatingButton then
        FloatBtn = Instance.new("TextButton", ScreenGui); FloatBtn.Size = UDim2.new(0, 65, 0, 65); FloatBtn.Position = UDim2.new(0, 40, 0, 40); FloatBtn.BackgroundColor3 = theme.Accent; FloatBtn.Text = "S"; FloatBtn.TextColor3 = theme.Text; FloatBtn.Font = Enum.Font.GothamBlack; FloatBtn.TextSize = 30; FloatBtn.Visible = false
        Instance.new("UICorner", FloatBtn).CornerRadius = UDim.new(1, 0); Instance.new("UIStroke", FloatBtn).Thickness = 3; MakeDraggable(FloatBtn, FloatBtn)
        FloatBtn.MouseButton1Click:Connect(function() MainFrame.Visible = not MainFrame.Visible; Ripple(FloatBtn) end)
    end

    -- SECURITY ACCESS SYSTEM
    if options.KeySystem then
        local KeyFrame = Instance.new("Frame", ScreenGui)
        KeyFrame.Size = UDim2.new(0, 400, 0, 220); KeyFrame.Position = UDim2.new(0.5, -200, 0.5, -110); KeyFrame.BackgroundColor3 = theme.Main; Instance.new("UICorner", KeyFrame); local KS = Instance.new("UIStroke", KeyFrame).Color = theme.Stroke
        local KT = Instance.new("TextLabel", KeyFrame); KT.Size = UDim2.new(1, 0, 0, 60); KT.Text = "ENCRYPTED ACCESS REQUIRED"; KT.TextColor3 = theme.Text; KT.Font = Enum.Font.GothamBold; KT.BackgroundTransparency = 1; KT.TextSize = 15
        local KI = Instance.new("TextBox", KeyFrame); KI.Size = UDim2.new(0.85, 0, 0, 50); KI.Position = UDim2.new(0.075, 0, 0.35, 0); KI.BackgroundColor3 = theme.Second; KI.TextColor3 = theme.Text; KI.PlaceholderText = "Paste access token..."; KI.Text = ""; Instance.new("UICorner", KI)
        local KB = Instance.new("TextButton", KeyFrame); KB.Size = UDim2.new(0.85, 0, 0, 50); KB.Position = UDim2.new(0.075, 0, 0.65, 0); KB.BackgroundColor3 = theme.Accent; KB.Text = "VALIDATE TOKEN"; KB.TextColor3 = theme.Text; KB.Font = Enum.Font.GothamBold; Instance.new("UICorner", KB)
        
        KB.MouseButton1Click:Connect(function()
            if KI.Text == options.KeySettings.Key then
                KeyFrame:Destroy(); MainFrame.Visible = true; if FloatBtn then FloatBtn.Visible = true end
                Survay:Notify({Title = "Verified", Content = "Access granted to " .. options.Name, Duration = 5})
            else
                KI.Text = ""; KI.PlaceholderText = "ACCESS DENIED"; task.wait(2); KI.PlaceholderText = "Paste access token..."
            end
        end)
    else
        MainFrame.Visible = true; if FloatBtn then FloatBtn.Visible = true end
    end

    local Tabs = {}; local FirstTab = true

    -- [[ TAB SYSTEM ]] --
    function Tabs:CreateTab(tName)
        local TabBtn = Instance.new("TextButton", TabHolder)
        TabBtn.Size = UDim2.new(1, 0, 0, 45); TabBtn.BackgroundColor3 = theme.Second; TabBtn.BackgroundTransparency = 0.25; TabBtn.Text = tName; TabBtn.TextColor3 = theme.Text; TabBtn.Font = Enum.Font.GothamBold; Instance.new("UICorner", TabBtn)
        
        local Page = Instance.new("ScrollingFrame", PageContainer)
        Page.Size = UDim2.new(1, 0, 1, 0); Page.BackgroundTransparency = 1; Page.ScrollBarThickness = 4; Page.Visible = FirstTab; Page.ScrollBarImageColor3 = theme.Accent; Page.CanvasSize = UDim2.new(0,0,0,0); Page.AutomaticCanvasSize = "Y"
        local PageList = Instance.new("UIListLayout", Page); PageList.Padding = UDim.new(0, 15); PageList.SortOrder = Enum.SortOrder.LayoutOrder
        local PagePad = Instance.new("UIPadding", Page); PagePad.PaddingLeft = UDim.new(0, 8); PagePad.PaddingRight = UDim.new(0, 12)
        FirstTab = false

        TabBtn.MouseButton1Click:Connect(function()
            for _, p in pairs(PageContainer:GetChildren()) do if p:IsA("ScrollingFrame") then p.Visible = false end end
            Page.Visible = true; Ripple(TabBtn)
        end)

        local Elements = {}

        -- [[ ELEMENT: INTERACTIVE BUTTON ]] --
        function Elements:CreateButton(cfg)
            local B = Instance.new("TextButton", Page)
            B.Size = UDim2.new(1, 0, 0, 48); B.BackgroundColor3 = theme.Second; B.Text = "  " .. cfg.Name; B.TextColor3 = theme.Text; B.Font = Enum.Font.GothamBold; B.TextXAlignment = 0; B.AutoButtonColor = false
            Instance.new("UICorner", B).CornerRadius = UDim.new(0, 12); local BS = Instance.new("UIStroke", B); BS.Color = theme.Stroke; BS.ApplyStrokeMode = "Border"
            B.MouseButton1Click:Connect(function() Ripple(B); cfg.Callback() end)
        end

        -- [[ ELEMENT: DYNAMIC TOGGLE ]] --
        function Elements:CreateToggle(cfg)
            local state = cfg.CurrentValue or false
            local T = Instance.new("TextButton", Page)
            T.Size = UDim2.new(1, 0, 0, 48); T.BackgroundColor3 = theme.Second; T.Text = "  " .. cfg.Name; T.TextColor3 = theme.Text; T.Font = Enum.Font.GothamBold; T.TextXAlignment = 0; T.AutoButtonColor = false
            Instance.new("UICorner", T).CornerRadius = UDim.new(0, 12); Instance.new("UIStroke", T).Color = theme.Stroke

            local Box = Instance.new("Frame", T)
            Box.Size = UDim2.new(0, 48, 0, 26); Box.Position = UDim2.new(1, -60, 0.5, -13); Box.BackgroundColor3 = state and theme.Accent or theme.Main; Instance.new("UICorner", Box).CornerRadius = UDim.new(1, 0)
            local Inner = Instance.new("Frame", Box); Inner.Size = UDim2.new(0, 22, 0, 22); Inner.Position = state and UDim2.new(1, -24, 0.5, -11) or UDim2.new(0, 2, 0.5, -11); Inner.BackgroundColor3 = theme.Text; Instance.new("UICorner", Inner).CornerRadius = UDim.new(1, 0)

            T.MouseButton1Click:Connect(function()
                state = not state
                CreateTween(Box, {0.3}, {BackgroundColor3 = state and theme.Accent or theme.Main})
                CreateTween(Inner, {0.3, Enum.EasingStyle.Back}, {Position = state and UDim2.new(1, -24, 0.5, -11) or UDim2.new(0, 2, 0.5, -11)})
                cfg.Callback(state)
            end)
        end

        -- [[ ELEMENT: VALUE SLIDER ]] --
        function Elements:CreateSlider(cfg)
            local S = Instance.new("Frame", Page)
            S.Size = UDim2.new(1, 0, 0, 65); S.BackgroundColor3 = theme.Second; Instance.new("UICorner", S); Instance.new("UIStroke", S).Color = theme.Stroke
            local Txt = Instance.new("TextLabel", S); Txt.Size = UDim2.new(1, -20, 0, 30); Txt.Position = UDim2.new(0, 15, 0, 5); Txt.Text = cfg.Name .. ": " .. cfg.CurrentValue; Txt.TextColor3 = theme.Text; Txt.BackgroundTransparency = 1; Txt.Font = Enum.Font.GothamBold; Txt.TextXAlignment = 0
            local Bar = Instance.new("TextButton", S); Bar.Size = UDim2.new(1, -40, 0, 12); Bar.Position = UDim2.new(0, 20, 0.7, 0); Bar.BackgroundColor3 = theme.Main; Bar.Text = ""; Instance.new("UICorner", Bar)
            local Fill = Instance.new("Frame", Bar); Fill.Size = UDim2.new((cfg.CurrentValue - cfg.Range[1]) / (cfg.Range[2] - cfg.Range[1]), 0, 1, 0); Fill.BackgroundColor3 = theme.Accent; Instance.new("UICorner", Fill)
            
            local dragging = false
            local function Update()
                local p = math.clamp((UserInputService:GetMouseLocation().X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
                local v = math.floor(cfg.Range[1] + (p * (cfg.Range[2] - cfg.Range[1])))
                Fill.Size = UDim2.new(p, 0, 1, 0); Txt.Text = cfg.Name .. ": " .. v; cfg.Callback(v)
            end
            Bar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = true end end)
            UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
            UserInputService.InputChanged:Connect(function(i) if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then Update() end end)
        end

        -- [[ ELEMENT: OPTION DROPDOWN ]] --
        function Elements:CreateDropdown(cfg)
            local open = false
            local D = Instance.new("Frame", Page)
            D.Size = UDim2.new(1, 0, 0, 48); D.BackgroundColor3 = theme.Second; D.ClipsDescendants = true; Instance.new("UICorner", D); Instance.new("UIStroke", D).Color = theme.Stroke
            local MB = Instance.new("TextButton", D); MB.Size = UDim2.new(1, 0, 0, 48); MB.BackgroundTransparency = 1; MB.Text = "  " .. cfg.Name .. ": " .. (cfg.CurrentOption or "..."); MB.TextColor3 = theme.Text; MB.Font = Enum.Font.GothamBold; MB.TextXAlignment = 0
            local List = Instance.new("Frame", D); List.Size = UDim2.new(1, -15, 0, #cfg.Options * 38); List.Position = UDim2.new(0, 7, 0, 55); List.BackgroundTransparency = 1
            local LL = Instance.new("UIListLayout", List); LL.Padding = UDim.new(0, 8)

            for _, opt in pairs(cfg.Options) do
                local O = Instance.new("TextButton", List)
                O.Size = UDim2.new(1, 0, 0, 32); O.BackgroundColor3 = theme.Main; O.Text = opt; O.TextColor3 = theme.Text; O.Font = Enum.Font.Gotham; Instance.new("UICorner", O)
                O.MouseButton1Click:Connect(function() MB.Text = "  " .. cfg.Name .. ": " .. opt; open = false; CreateTween(D, {0.5, Enum.EasingStyle.Quart}, {Size = UDim2.new(1, 0, 0, 48)}); cfg.Callback(opt) end)
            end
            MB.MouseButton1Click:Connect(function() open = not open; CreateTween(D, {0.5, Enum.EasingStyle.Quart}, {Size = open and UDim2.new(1, 0, 0, 65 + (#cfg.Options * 38)) or UDim2.new(1, 0, 0, 48)}) end)
        end

        -- [[ ELEMENT: TEXT INPUT FIELD ]] --
        function Elements:CreateInput(cfg)
            local I = Instance.new("Frame", Page)
            I.Size = UDim2.new(1, 0, 0, 60); I.BackgroundColor3 = theme.Second; Instance.new("UICorner", I); Instance.new("UIStroke", I).Color = theme.Stroke
            local TB = Instance.new("TextBox", I)
            TB.Size = UDim2.new(1, -30, 0, 40); TB.Position = UDim2.new(0, 15, 0.5, -20); TB.BackgroundColor3 = theme.Main; TB.TextColor3 = theme.Text; TB.PlaceholderText = cfg.Name .. "..."; TB.Text = ""; Instance.new("UICorner", TB)
            TB.FocusLost:Connect(function() cfg.Callback(TB.Text) end)
        end

        -- [[ ELEMENT: MACRO KEYBIND ]] --
        function Elements:CreateKeybind(cfg)
            local key = cfg.CurrentKey or Enum.KeyCode.F
            local K = Instance.new("TextButton", Page)
            K.Size = UDim2.new(1, 0, 0, 48); K.BackgroundColor3 = theme.Second; K.Text = "  " .. cfg.Name; K.TextColor3 = theme.Text; K.Font = Enum.Font.GothamBold; K.TextXAlignment = 0; Instance.new("UICorner", K); Instance.new("UIStroke", K).Color = theme.Stroke
            local L = Instance.new("TextLabel", K); L.Size = UDim2.new(0, 80, 0, 30); L.Position = UDim2.new(1, -90, 0.5, -15); L.BackgroundColor3 = theme.Accent; L.Text = key.Name; L.TextColor3 = theme.Text; L.Font = Enum.Font.GothamBold; Instance.new("UICorner", L)
            
            K.MouseButton1Click:Connect(function()
                L.Text = "..."; local input = UserInputService.InputBegan:Wait()
                if input.KeyCode ~= Enum.KeyCode.Unknown then key = input.KeyCode; L.Text = key.Name; cfg.Callback(key) end
            end)
            UserInputService.InputBegan:Connect(function(i, gpe) if not gpe and i.KeyCode == key then cfg.Callback(key) end end)
        end

        -- [[ ELEMENT: VISUAL SECTION HEADER ]] --
        function Elements:CreateSection(sName)
            local S = Instance.new("Frame", Page)
            S.Size = UDim2.new(1, 0, 0, 35); S.BackgroundTransparency = 1
            local ST = Instance.new("TextLabel", S); ST.Size = UDim2.new(1, 0, 1, 0); ST.Text = "::  " .. sName:upper() .. "  ::"; ST.TextColor3 = theme.Accent; ST.Font = Enum.Font.GothamBold; ST.BackgroundTransparency = 1; ST.TextSize = 14
        end

        -- [[ ELEMENT: RICH TEXT PARAGRAPH ]] --
        function Elements:CreateParagraph(cfg)
            local P = Instance.new("Frame", Page)
            P.Size = UDim2.new(1, 0, 0, 80); P.BackgroundColor3 = theme.Second; P.BackgroundTransparency = 0.5; Instance.new("UICorner", P)
            local T = Instance.new("TextLabel", P); T.Size = UDim2.new(1, -24, 1, -14); T.Position = UDim2.new(0, 12, 0, 7); T.Text = "<b>" .. cfg.Title .. "</b>\n" .. cfg.Content; T.TextColor3 = theme.Text; T.Font = Enum.Font.Gotham; T.TextSize = 12; T.TextXAlignment = 0; T.TextYAlignment = 0; T.BackgroundTransparency = 1; T.TextWrapped = true; T.RichText = true
        end

        return Elements
    end
    return Tabs
end

-- Finalizing Module Exports
return Survay
