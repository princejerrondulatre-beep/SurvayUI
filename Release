local SurvayLib = {}
SurvayLib.__index = SurvayLib

function Survay:Create(options)
	options = options or {}
	local self = setmetatable({}, SurvayLib)
	self.Name = options.Name or "Survay"
	self.ThemeName = options.Theme or "Default"
	self.Theme = deepCopy(Themes[self.ThemeName] or Themes.Default)
	self.Key = options.Key
	self.KeySystem = options.KeySystem or false
	self.SaveConfig = options.SaveConfig or false
	self.Tabs = {}
	self.Notifications = {}
	self.FloatingButton = nil
	self.Gui = Instance.new("ScreenGui")
	self.Gui.Name = "Survay_"..math.random(1000,9999)
	self.Gui.Parent = options.Parent or CoreGui
	self.Gui.ResetOnSpawn = false
	self.Gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

	-- Key system check
	if self.KeySystem then
		local valid = false
		local whitelist = {"Survay123","TestKey","FreeKey","Premium"}
		if self.Key and table.find(whitelist, self.Key) then
			valid = true
		end
		if not valid then
			self:_showKeyPrompt()
			return self
		end
	end

	self:_buildUI()
	return self
end

function SurvayLib:_showKeyPrompt()
	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(0,300,0,160)
	frame.Position = UDim2.new(0.5,-150,0.5,-80)
	frame.BackgroundColor3 = self.Theme.Background
	frame.BorderSizePixel = 0
	frame.Parent = self.Gui
	Instance.new("UICorner", frame).CornerRadius = UDim.new(0,8)
	Instance.new("UIStroke", frame).Color = self.Theme.Border

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1,0,0,30)
	title.BackgroundTransparency = 1
	title.Text = "🔑 Enter License Key"
	title.TextColor3 = self.Theme.Text
	title.Font = Enum.Font.GothamBold
	title.TextSize = 18
	title.Parent = frame

	local input = Instance.new("TextBox")
	input.Size = UDim2.new(1,-20,0,45)
	input.Position = UDim2.new(0,10,0,40)
	input.BackgroundColor3 = self.Theme.Main
	input.TextColor3 = self.Theme.Text
	input.PlaceholderText = "Key..."
	input.Font = Enum.Font.Gotham
	input.TextSize = 16
	input.Parent = frame
	Instance.new("UICorner", input).CornerRadius = UDim.new(0,6)

	local submit = Instance.new("TextButton")
	submit.Size = UDim2.new(1,-20,0,40)
	submit.Position = UDim2.new(0,10,0,95)
	submit.BackgroundColor3 = self.Theme.Accent
	submit.TextColor3 = self.Theme.Text
	submit.Text = "Submit"
	submit.Font = Enum.Font.GothamBold
	submit.TextSize = 16
	submit.Parent = frame
	Instance.new("UICorner", submit).CornerRadius = UDim.new(0,6)

	local status = Instance.new("TextLabel")
	status.Size = UDim2.new(1,0,0,20)
	status.Position = UDim2.new(0,0,1,5)
	status.BackgroundTransparency = 1
	status.Text = ""
	status.TextColor3 = Color3.fromRGB(255,100,100)
	status.Font = Enum.Font.Gotham
	status.TextSize = 12
	status.Parent = frame

	submit.MouseButton1Click:Connect(function()
		local entered = input.Text
		local whitelist = {"Survay123","TestKey","FreeKey","Premium"}
		if table.find(whitelist, entered) then
			self.Key = entered
			frame:Destroy()
			self:_buildUI()
		else
			status.Text = "❌ Invalid key"
			input.Text = ""
		end
	end)
end

function SurvayLib:_buildUI()
	-- Main window
	local main = Instance.new("Frame")
	main.Name = "Main"
	main.Size = UDim2.new(0,650,0,450)
	main.Position = UDim2.new(0.5,-325,0.5,-225)
	main.BackgroundColor3 = self.Theme.Background
	main.BackgroundTransparency = 0
	main.BorderSizePixel = 0
	main.ClipsDescendants = true
	main.Parent = self.Gui
	self.MainFrame = main

	-- Drop shadow effect
	local shadow = Instance.new("ImageLabel")
	shadow.Name = "Shadow"
	shadow.Size = UDim2.new(1,20,1,20)
	shadow.Position = UDim2.new(0,-10,0,-10)
	shadow.BackgroundTransparency = 1
	shadow.Image = "rbxassetid://6014261993"
	shadow.ImageColor3 = self.Theme.Shadow
	shadow.ImageTransparency = 0.5
	shadow.ScaleType = Enum.ScaleType.Slice
	shadow.SliceCenter = Rect.new(10,10,118,118)
	shadow.ZIndex = 0
	shadow.Parent = main
	main.ZIndex = 1

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0,8)
	corner.Parent = main

	-- Drag bar
	local dragBar = Instance.new("Frame")
	dragBar.Size = UDim2.new(1,0,0,36)
	dragBar.BackgroundColor3 = self.Theme.Main
	dragBar.BorderSizePixel = 0
	dragBar.Parent = main
	Instance.new("UICorner", dragBar).CornerRadius = UDim.new(0,8)
	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1,-50,1,0)
	title.Position = UDim2.new(0,15,0,0)
	title.BackgroundTransparency = 1
	title.Text = self.Name
	title.TextColor3 = self.Theme.Text
	title.Font = Enum.Font.GothamBold
	title.TextSize = 18
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Parent = dragBar

	local closeBtn = Instance.new("TextButton")
	closeBtn.Size = UDim2.new(0,36,0,36)
	closeBtn.Position = UDim2.new(1,-36,0,0)
	closeBtn.BackgroundColor3 = self.Theme.Accent
	closeBtn.Text = "✕"
	closeBtn.TextColor3 = self.Theme.Text
	closeBtn.Font = Enum.Font.GothamBold
	closeBtn.TextSize = 20
	closeBtn.Parent = dragBar
	Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0,8)
	closeBtn.MouseButton1Click:Connect(function()
		main.Visible = false
		if self.FloatingButton then
			self.FloatingButton.Visible = true
		end
	end)

	makeDraggable(main, dragBar)

	-- Tabs container
	local tabContainer = Instance.new("Frame")
	tabContainer.Size = UDim2.new(0,160,1,-36)
	tabContainer.Position = UDim2.new(0,0,0,36)
	tabContainer.BackgroundColor3 = self.Theme.Main
	tabContainer.BorderSizePixel = 0
	tabContainer.Parent = main
	Instance.new("UICorner", tabContainer).CornerRadius = UDim.new(0,8)
	local tabList = Instance.new("UIListLayout")
	tabList.SortOrder = Enum.SortOrder.LayoutOrder
	tabList.Padding = UDim.new(0,2)
	tabList.Parent = tabContainer

	-- Content container
	local content = Instance.new("Frame")
	content.Size = UDim2.new(1,-160,1,-36)
	content.Position = UDim2.new(0,160,0,36)
	content.BackgroundColor3 = self.Theme.Background
	content.BorderSizePixel = 0
	content.ClipsDescendants = true
	content.Parent = main
	self.ContentContainer = content
	self.TabContainer = tabContainer

	-- Floating toggle button
	self:_createFloatingButton()
end

function SurvayLib:_createFloatingButton()
	local btn = Instance.new("ImageButton")
	btn.Size = UDim2.new(0,52,0,52)
	btn.Position = UDim2.new(1,-70,1,-70)
	btn.BackgroundColor3 = self.Theme.Accent
	btn.Image = "rbxassetid://6031221441" -- circle icon
	btn.ImageColor3 = self.Theme.Text
	btn.BorderSizePixel = 0
	btn.Visible = false
	btn.Parent = self.Gui
	btn.ZIndex = 10
	Instance.new("UICorner", btn).CornerRadius = UDim.new(1,0)
	Instance.new("UIStroke", btn).Color = self.Theme.Border
	makeDraggable(btn)
	btn.MouseButton1Click:Connect(function()
		self.MainFrame.Visible = not self.MainFrame.Visible
		btn.Visible = not self.MainFrame.Visible
	end)
	self.FloatingButton = btn
end

function SurvayLib:CreateFloatingButton()
	if self.FloatingButton then
		self.FloatingButton.Visible = true
		if self.MainFrame then
			self.MainFrame.Visible = false
		end
	end
end

function SurvayLib:Transparent()
	if self.MainFrame then
		self.MainFrame.BackgroundTransparency = 0.5
	end
end

function SurvayLib:CreateTab(name)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1,-10,0,38)
	btn.Position = UDim2.new(0,5,0,0)
	btn.BackgroundColor3 = self.Theme.Main
	btn.TextColor3 = self.Theme.Text
	btn.Text = name
	btn.Font = Enum.Font.Gotham
	btn.TextSize = 15
	btn.BorderSizePixel = 0
	btn.Parent = self.TabContainer
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)

	local page = Instance.new("ScrollingFrame")
	page.Size = UDim2.new(1,0,1,0)
	page.BackgroundTransparency = 1
	page.BorderSizePixel = 0
	page.ScrollBarThickness = 4
	page.ScrollBarImageColor3 = self.Theme.Accent
	page.CanvasSize = UDim2.new(0,0,0,0)
	page.Parent = self.ContentContainer
	page.Visible = false

	local list = Instance.new("UIListLayout")
	list.SortOrder = Enum.SortOrder.LayoutOrder
	list.Padding = UDim.new(0,6)
	list.Parent = page

	local tab = {Button=btn, Page=page, List=list, Sections={}}
	table.insert(self.Tabs, tab)

	btn.MouseButton1Click:Connect(function()
		for _, t in ipairs(self.Tabs) do
			t.Page.Visible = false
		end
		page.Visible = true
	end)

	if #self.Tabs == 1 then
		page.Visible = true
	end

	local function updateCanvas()
		local h = 0
		for _, child in ipairs(page:GetChildren()) do
			if child:IsA("Frame") then
				h = h + child.AbsoluteSize.Y + 6
			end
		end
		page.CanvasSize = UDim2.new(0,0,0,h+10)
	end
	page.ChildAdded:Connect(updateCanvas)
	page.ChildRemoved:Connect(updateCanvas)
	list:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)

	local methods = {}
	function methods:CreateSection(title)
		local sectionFrame = Instance.new("Frame")
		sectionFrame.Size = UDim2.new(1,-10,0,30)
		sectionFrame.Position = UDim2.new(0,5,0,0)
		sectionFrame.BackgroundTransparency = 1
		sectionFrame.Parent = page

		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1,0,1,0)
		label.BackgroundTransparency = 1
		label.Text = title
		label.TextColor3 = self.Theme.Text
		label.Font = Enum.Font.GothamBold
		label.TextSize = 14
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.Parent = sectionFrame

		local contentFrame = Instance.new("Frame")
		contentFrame.Size = UDim2.new(1,-10,0,0)
		contentFrame.BackgroundTransparency = 1
		contentFrame.Parent = page

		local contentList = Instance.new("UIListLayout")
		contentList.SortOrder = Enum.SortOrder.LayoutOrder
		contentList.Padding = UDim.new(0,5)
		contentList.Parent = contentFrame

		local section = {Frame=contentFrame, List=contentList}

		-- Add methods
		function section:AddButton(opt)
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1,0,0,40)
			btn.BackgroundColor3 = self.Theme.Main
			btn.TextColor3 = self.Theme.Text
			btn.Text = opt.Name or "Button"
			btn.Font = Enum.Font.Gotham
			btn.TextSize = 14
			btn.BorderSizePixel = 0
			btn.Parent = contentFrame
			Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)
			if opt.Callback then
				btn.MouseButton1Click:Connect(opt.Callback)
			end
			return btn
		end

		function section:AddToggle(opt)
			local frame = Instance.new("Frame")
			frame.Size = UDim2.new(1,0,0,40)
			frame.BackgroundColor3 = self.Theme.Main
			frame.BorderSizePixel = 0
			frame.Parent = contentFrame
			Instance.new("UICorner", frame).CornerRadius = UDim.new(0,6)

			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(0.7,0,1,0)
			label.Position = UDim2.new(0,12,0,0)
			label.BackgroundTransparency = 1
			label.Text = opt.Name or "Toggle"
			label.TextColor3 = self.Theme.Text
			label.Font = Enum.Font.Gotham
			label.TextSize = 14
			label.TextXAlignment = Enum.TextXAlignment.Left
			label.Parent = frame

			local toggleBtn = Instance.new("TextButton")
			toggleBtn.Size = UDim2.new(0,44,0,22)
			toggleBtn.Position = UDim2.new(1,-56,0.5,-11)
			toggleBtn.BackgroundColor3 = self.Theme.Border
			toggleBtn.Text = ""
			toggleBtn.BorderSizePixel = 0
			toggleBtn.Parent = frame
			Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(1,0)

			local knob = Instance.new("Frame")
			knob.Size = UDim2.new(0,18,0,18)
			knob.Position = UDim2.new(0,2,0.5,-9)
			knob.BackgroundColor3 = self.Theme.Text
			knob.BorderSizePixel = 0
			knob.Parent = toggleBtn
			Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

			local toggled = opt.Default or false
			local function update()
				if toggled then
					toggleBtn.BackgroundColor3 = self.Theme.Accent
					tween(knob, {Position = UDim2.new(1,-20,0.5,-9)}, 0.2)
				else
					toggleBtn.BackgroundColor3 = self.Theme.Border
					tween(knob, {Position = UDim2.new(0,2,0.5,-9)}, 0.2)
				end
				if opt.Callback then opt.Callback(toggled) end
			end
			toggleBtn.MouseButton1Click:Connect(function()
				toggled = not toggled
				update()
			end)
			update()
			return {Set=function(v) toggled=v; update() end}
		end

		function section:AddSlider(opt)
			local frame = Instance.new("Frame")
			frame.Size = UDim2.new(1,0,0,60)
			frame.BackgroundColor3 = self.Theme.Main
			frame.BorderSizePixel = 0
			frame.Parent = contentFrame
			Instance.new("UICorner", frame).CornerRadius = UDim.new(0,6)

			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(1,-80,0,20)
			label.Position = UDim2.new(0,12,0,6)
			label.BackgroundTransparency = 1
			label.Text = opt.Name or "Slider"
			label.TextColor3 = self.Theme.Text
			label.Font = Enum.Font.Gotham
			label.TextSize = 14
			label.TextXAlignment = Enum.TextXAlignment.Left
			label.Parent = frame

			local valLabel = Instance.new("TextLabel")
			valLabel.Size = UDim2.new(0,60,0,20)
			valLabel.Position = UDim2.new(1,-70,0,6)
			valLabel.BackgroundTransparency = 1
			valLabel.Text = tostring(opt.Default or opt.Min or 0)
			valLabel.TextColor3 = self.Theme.Accent
			valLabel.Font = Enum.Font.Gotham
			valLabel.TextSize = 14
			valLabel.TextXAlignment = Enum.TextXAlignment.Right
			valLabel.Parent = frame

			local bar = Instance.new("Frame")
			bar.Size = UDim2.new(1,-24,0,6)
			bar.Position = UDim2.new(0,12,0,36)
			bar.BackgroundColor3 = self.Theme.Border
			bar.BorderSizePixel = 0
			bar.Parent = frame
			Instance.new("UICorner", bar).CornerRadius = UDim.new(1,0)

			local fill = Instance.new("Frame")
			fill.Size = UDim2.new(0,0,1,0)
			fill.BackgroundColor3 = self.Theme.Accent
			fill.BorderSizePixel = 0
			fill.Parent = bar
			Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)

			local minVal, maxVal = opt.Min or 0, opt.Max or 100
			local current = opt.Default or minVal
			local function setValue(v)
				v = math.clamp(v, minVal, maxVal)
				current = v
				local percent = (v-minVal)/(maxVal-minVal)
				fill.Size = UDim2.new(percent,0,1,0)
				valLabel.Text = string.format("%.2f", v)
				if opt.Callback then opt.Callback(v) end
			end
			local dragging = false
			bar.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = true
					local mx = UserInputService:GetMouseLocation().X
					local rel = (mx - bar.AbsolutePosition.X) / bar.AbsoluteSize.X
					setValue(minVal + rel*(maxVal-minVal))
				end
			end)
			bar.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
			end)
			UserInputService.InputChanged:Connect(function(i)
				if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
					local rel = (i.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X
					setValue(minVal + rel*(maxVal-minVal))
				end
			end)
			setValue(current)
			return {Set=setValue}
		end

		function section:AddInput(opt)
			local frame = Instance.new("Frame")
			frame.Size = UDim2.new(1,0,0,40)
			frame.BackgroundColor3 = self.Theme.Main
			frame.BorderSizePixel = 0
			frame.Parent = contentFrame
			Instance.new("UICorner", frame).CornerRadius = UDim.new(0,6)

			local box = Instance.new("TextBox")
			box.Size = UDim2.new(1,-20,1,0)
			box.Position = UDim2.new(0,10,0,0)
			box.BackgroundTransparency = 1
			box.Text = opt.Default or ""
			box.PlaceholderText = opt.Placeholder or "Enter text..."
			box.TextColor3 = self.Theme.Text
			box.PlaceholderColor3 = self.Theme.Border
			box.Font = Enum.Font.Gotham
			box.TextSize = 14
			box.TextXAlignment = Enum.TextXAlignment.Left
			box.Parent = frame
			if opt.Callback then
				box.FocusLost:Connect(function(enter)
					opt.Callback(box.Text, enter)
				end)
			end
			return box
		end

		function section:AddColorPicker(opt)
			local frame = Instance.new("Frame")
			frame.Size = UDim2.new(1,0,0,40)
			frame.BackgroundColor3 = self.Theme.Main
			frame.BorderSizePixel = 0
			frame.Parent = contentFrame
			Instance.new("UICorner", frame).CornerRadius = UDim.new(0,6)

			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(0.7,0,1,0)
			label.Position = UDim2.new(0,12,0,0)
			label.BackgroundTransparency = 1
			label.Text = opt.Name or "Color"
			label.TextColor3 = self.Theme.Text
			label.Font = Enum.Font.Gotham
			label.TextSize = 14
			label.TextXAlignment = Enum.TextXAlignment.Left
			label.Parent = frame

			local preview = Instance.new("Frame")
			preview.Size = UDim2.new(0,32,0,32)
			preview.Position = UDim2.new(1,-44,0.5,-16)
			preview.BackgroundColor3 = opt.Default or self.Theme.Accent
			preview.BorderSizePixel = 0
			preview.Parent = frame
			Instance.new("UICorner", preview).CornerRadius = UDim.new(0,6)
			Instance.new("UIStroke", preview).Color = self.Theme.Border

			local pickerOpen = false
			local pickerGui
			preview.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 and not pickerOpen then
					pickerOpen = true
					pickerGui = Instance.new("Frame")
					pickerGui.Size = UDim2.new(0,220,0,220)
					pickerGui.Position = UDim2.new(0, Mouse.X-110, 0, Mouse.Y-110)
					pickerGui.BackgroundColor3 = self.Theme.Background
					pickerGui.BorderSizePixel = 0
					pickerGui.Parent = self.Gui
					Instance.new("UICorner", pickerGui).CornerRadius = UDim.new(0,8)
					Instance.new("UIStroke", pickerGui).Color = self.Theme.Border
					makeDraggable(pickerGui)

					local hueBar = Instance.new("Frame")
					hueBar.Size = UDim2.new(0,20,1,-20)
					hueBar.Position = UDim2.new(1,-30,0,10)
					hueBar.BackgroundColor3 = Color3.new(1,1,1)
					hueBar.BorderSizePixel = 0
					hueBar.Parent = pickerGui
					local hueGrad = Instance.new("UIGradient")
					hueGrad.Color = ColorSequence.new{
						ColorSequenceKeypoint.new(0, Color3.fromRGB(255,0,0)),
						ColorSequenceKeypoint.new(0.16, Color3.fromRGB(255,255,0)),
						ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0,255,0)),
						ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0,255,255)),
						ColorSequenceKeypoint.new(0.66, Color3.fromRGB(0,0,255)),
						ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255,0,255)),
						ColorSequenceKeypoint.new(1, Color3.fromRGB(255,0,0))
					}
					hueGrad.Rotation = 90
					hueGrad.Parent = hueBar
					local hueKnob = Instance.new("Frame")
					hueKnob.Size = UDim2.new(1,0,0,4)
					hueKnob.BackgroundColor3 = Color3.new(1,1,1)
					hueKnob.BorderSizePixel = 0
					hueKnob.Parent = hueBar

					local svBox = Instance.new("Frame")
					svBox.Size = UDim2.new(1,-40,1,-20)
					svBox.Position = UDim2.new(0,10,0,10)
					svBox.BackgroundColor3 = Color3.new(1,0,0)
					svBox.BorderSizePixel = 0
					svBox.Parent = pickerGui
					local whiteGrad = Instance.new("UIGradient")
					whiteGrad.Color = ColorSequence.new(Color3.new(1,1,1))
					whiteGrad.Transparency = NumberSequence.new{NumberSequenceKeypoint.new(0,0), NumberSequenceKeypoint.new(1,1)}
					whiteGrad.Rotation = 0
					whiteGrad.Parent = svBox
					local blackGrad = Instance.new("UIGradient")
					blackGrad.Color = ColorSequence.new(Color3.new(0,0,0))
					blackGrad.Transparency = NumberSequence.new{NumberSequenceKeypoint.new(0,1), NumberSequenceKeypoint.new(1,0)}
					blackGrad.Rotation = -90
					blackGrad.Parent = svBox
					local svKnob = Instance.new("Frame")
					svKnob.Size = UDim2.new(0,8,0,8)
					svKnob.BackgroundColor3 = Color3.new(1,1,1)
					svKnob.BorderSizePixel = 2
					svKnob.BorderColor3 = Color3.new(0,0,0)
					svKnob.Parent = svBox

					local hue, sat, val = 0,1,1
					local function updateColor()
						local col = Color3.fromHSV(hue, sat, val)
						preview.BackgroundColor3 = col
						svBox.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
						if opt.Callback then opt.Callback(col) end
					end
					local draggingHue, draggingSV = false, false
					hueBar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then draggingHue = true end end)
					hueBar.InputEnded:Connect(function() draggingHue = false end)
					svBox.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then draggingSV = true end end)
					svBox.InputEnded:Connect(function() draggingSV = false end)
					UserInputService.InputChanged:Connect(function(i)
						if draggingHue and i.UserInputType == Enum.UserInputType.MouseMovement then
							local y = math.clamp((i.Position.Y - hueBar.AbsolutePosition.Y)/hueBar.AbsoluteSize.Y, 0, 1)
							hue = y
							hueKnob.Position = UDim2.new(0,0,y,-2)
							updateColor()
						elseif draggingSV and i.UserInputType == Enum.UserInputType.MouseMovement then
							local x = math.clamp((i.Position.X - svBox.AbsolutePosition.X)/svBox.AbsoluteSize.X, 0, 1)
							local y = math.clamp((i.Position.Y - svBox.AbsolutePosition.Y)/svBox.AbsoluteSize.Y, 0, 1)
							sat = x
							val = 1 - y
							svKnob.Position = UDim2.new(x,-4,y,-4)
							updateColor()
						end
					end)
					local closeConn
					closeConn = UserInputService.InputBegan:Connect(function(i)
						if i.UserInputType == Enum.UserInputType.MouseButton1 then
							if not pickerGui:IsAncestorOf(i.Target) and i.Target ~= preview then
								pickerGui:Destroy()
								pickerOpen = false
								closeConn:Disconnect()
							end
						end
					end)
					local def = opt.Default or self.Theme.Accent
					hue, sat, val = def:ToHSV()
					svBox.BackgroundColor3 = Color3.fromHSV(hue,1,1)
					hueKnob.Position = UDim2.new(0,0,hue,-2)
					svKnob.Position = UDim2.new(sat,-4,1-val,-4)
					updateColor()
				end
			end)
			return {SetColor=function(c) preview.BackgroundColor3 = c; if opt.Callback then opt.Callback(c) end end}
		end

		function section:AddDropdown(opt)
			local frame = Instance.new("Frame")
			frame.Size = UDim2.new(1,0,0,40)
			frame.BackgroundColor3 = self.Theme.Main
			frame.BorderSizePixel = 0
			frame.Parent = contentFrame
			Instance.new("UICorner", frame).CornerRadius = UDim.new(0,6)

			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1,-20,1,0)
			btn.Position = UDim2.new(0,10,0,0)
			btn.BackgroundTransparency = 1
			btn.Text = opt.Name or "Dropdown"
			btn.TextColor3 = self.Theme.Text
			btn.Font = Enum.Font.Gotham
			btn.TextSize = 14
			btn.TextXAlignment = Enum.TextXAlignment.Left
			btn.Parent = frame

			local open = false
			local dropFrame
			btn.MouseButton1Click:Connect(function()
				if open then
					if dropFrame then dropFrame:Destroy() end
					open = false
					return
				end
				open = true
				dropFrame = Instance.new("Frame")
				dropFrame.Size = UDim2.new(1,0,0,#opt.Options*30+10)
				dropFrame.Position = UDim2.new(0,0,1,5)
				dropFrame.BackgroundColor3 = self.Theme.Main
				dropFrame.BorderSizePixel = 0
				dropFrame.Parent = frame
				Instance.new("UICorner", dropFrame).CornerRadius = UDim.new(0,6)
				Instance.new("UIStroke", dropFrame).Color = self.Theme.Border
				local list = Instance.new("UIListLayout")
				list.SortOrder = Enum.SortOrder.LayoutOrder
				list.Parent = dropFrame

				for _, option in ipairs(opt.Options) do
					local optBtn = Instance.new("TextButton")
					optBtn.Size = UDim2.new(1,-10,0,26)
					optBtn.Position = UDim2.new(0,5,0,0)
					optBtn.BackgroundColor3 = self.Theme.Background
					optBtn.Text = option
					optBtn.TextColor3 = self.Theme.Text
					optBtn.Font = Enum.Font.Gotham
					optBtn.TextSize = 13
					optBtn.Parent = dropFrame
					Instance.new("UICorner", optBtn).CornerRadius = UDim.new(0,4)
					optBtn.MouseButton1Click:Connect(function()
						btn.Text = option
						if opt.Callback then opt.Callback(option) end
						dropFrame:Destroy()
						open = false
					end)
				end
			end)
		end

		function section:AddKeybind(opt)
			local frame = Instance.new("Frame")
			frame.Size = UDim2.new(1,0,0,40)
			frame.BackgroundColor3 = self.Theme.Main
			frame.BorderSizePixel = 0
			frame.Parent = contentFrame
			Instance.new("UICorner", frame).CornerRadius = UDim.new(0,6)

			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(0.6,0,1,0)
			label.Position = UDim2.new(0,12,0,0)
			label.BackgroundTransparency = 1
			label.Text = opt.Name or "Keybind"
			label.TextColor3 = self.Theme.Text
			label.Font = Enum.Font.Gotham
			label.TextSize = 14
			label.TextXAlignment = Enum.TextXAlignment.Left
			label.Parent = frame

			local bindBtn = Instance.new("TextButton")
			bindBtn.Size = UDim2.new(0,70,0,28)
			bindBtn.Position = UDim2.new(1,-82,0.5,-14)
			bindBtn.BackgroundColor3 = self.Theme.Border
			bindBtn.Text = opt.Default or "None"
			bindBtn.TextColor3 = self.Theme.Text
			bindBtn.Font = Enum.Font.Gotham
			bindBtn.TextSize = 12
			bindBtn.Parent = frame
			Instance.new("UICorner", bindBtn).CornerRadius = UDim.new(0,4)

			local binding = false
			local currentKey = opt.Default
			bindBtn.MouseButton1Click:Connect(function()
				binding = true
				bindBtn.Text = "..."
				local conn
				conn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
					if not gameProcessed and binding then
						local key = input.KeyCode
						if key ~= Enum.KeyCode.Unknown then
							currentKey = key.Name
							bindBtn.Text = key.Name
							binding = false
							conn:Disconnect()
							if opt.Callback then opt.Callback(key) end
						end
					end
				end)
			end)
		end

		function section:AddLabel(text)
			local lbl = Instance.new("TextLabel")
			lbl.Size = UDim2.new(1,0,0,25)
			lbl.BackgroundTransparency = 1
			lbl.Text = text
			lbl.TextColor3 = self.Theme.Text
			lbl.Font = Enum.Font.Gotham
			lbl.TextSize = 13
			lbl.TextXAlignment = Enum.TextXAlignment.Left
			lbl.Parent = contentFrame
			return lbl
		end

		function section:AddParagraph(title, content)
			local frame = Instance.new("Frame")
			frame.Size = UDim2.new(1,0,0,60)
			frame.BackgroundColor3 = self.Theme.Main
			frame.BorderSizePixel = 0
			frame.Parent = contentFrame
			Instance.new("UICorner", frame).CornerRadius = UDim.new(0,6)

			local t = Instance.new("TextLabel")
			t.Size = UDim2.new(1,-16,0,20)
			t.Position = UDim2.new(0,8,0,5)
			t.BackgroundTransparency = 1
			t.Text = title
			t.TextColor3 = self.Theme.Accent
			t.Font = Enum.Font.GothamBold
			t.TextSize = 13
			t.TextXAlignment = Enum.TextXAlignment.Left
			t.Parent = frame

			local c = Instance.new("TextLabel")
			c.Size = UDim2.new(1,-16,0,30)
			c.Position = UDim2.new(0,8,0,28)
			c.BackgroundTransparency = 1
			c.Text = content
			c.TextColor3 = self.Theme.Text
			c.Font = Enum.Font.Gotham
			c.TextSize = 12
			c.TextWrapped = true
			c.TextXAlignment = Enum.TextXAlignment.Left
			c.Parent = frame
		end

		table.insert(tab.Sections, section)
		return section
	end
	return methods
end

function SurvayLib:Notification(opt)
	local notif = Instance.new("Frame")
	notif.Size = UDim2.new(0,280,0,70)
	notif.Position = UDim2.new(1,-290,1,-80)
	notif.BackgroundColor3 = self.Theme.Main
	notif.BorderSizePixel = 0
	notif.Parent = self.Gui
	notif.ZIndex = 100
	Instance.new("UICorner", notif).CornerRadius = UDim.new(0,8)
	Instance.new("UIStroke", notif).Color = self.Theme.Accent

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1,-20,0,22)
	title.Position = UDim2.new(0,10,0,6)
	title.BackgroundTransparency = 1
	title.Text = opt.Title or "Notification"
	title.TextColor3 = self.Theme.Accent
	title.Font = Enum.Font.GothamBold
	title.TextSize = 14
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Parent = notif

	local content = Instance.new("TextLabel")
	content.Size = UDim2.new(1,-20,0,34)
	content.Position = UDim2.new(0,10,0,30)
	content.BackgroundTransparency = 1
	content.Text = opt.Content or ""
	content.TextColor3 = self.Theme.Text
	content.Font = Enum.Font.Gotham
	content.TextSize = 13
	content.TextWrapped = true
	content.TextXAlignment = Enum.TextXAlignment.Left
	content.Parent = notif

	local count = #self.Notifications
	notif.Position = UDim2.new(1,-290,1,-80 - count*80)
	table.insert(self.Notifications, notif)

	delay(opt.Duration or 3, function()
		tween(notif, {Position = UDim2.new(1,10,1,-80 - count*80)}, 0.3)
		wait(0.3)
		notif:Destroy()
		for i,v in ipairs(self.Notifications) do
			if v == notif then table.remove(self.Notifications, i) break end
		end
	end)
end

function SurvayLib:Destroy()
	if self.Gui then self.Gui:Destroy() end
end

return Survay
